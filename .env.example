# LLM API fallback. Keep real values in deployment secrets, never in git.
MODEL_API_KEY=
MODEL_BASE_URL=
MODEL_NAME=

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=

# PostgreSQL for users, sessions, chat history, and long-term memory.
# Use sqlite only for local smoke tests. Production should use PostgreSQL.
DATABASE_URL=postgresql://medical_kg_user:medical_kg_pg_2026@localhost:15433/medical_kg

# Embedding model used by the current FAISS entity-alignment index.
EMBEDDING_MODEL_PATH=

# Local TCM extraction model.
TCM_EXTRACTOR_BACKEND=auto
TCM_EXTRACTOR_BASE_MODEL=Qwen/Qwen2.5-1.5B-Instruct
TCM_EXTRACTOR_ADAPTER_PATH=models/tcm_extractor_lora

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000

# Comma-separated frontend origins allowed by FastAPI CORS in production.
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
